<?xml version="1.0" encoding="utf-8"?>
<!-- res/drawable/neon_card_cyan.xml -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- outer glow -->
    <item android:left="2dp" android:top="2dp" android:right="2dp" android:bottom="2dp">
        <shape android:shape="rectangle">
            <corners android:radius="28dp"/>
            <stroke android:width="4dp" android:color="#202ACFD9"/>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>
    <!-- card body -->
    <item android:left="4dp" android:top="4dp" android:right="4dp" android:bottom="4dp">
        <shape android:shape="rectangle">
            <corners android:radius="26dp"/>
            <solid android:color="#1A1F2E"/>
            <stroke android:width="1dp" android:color="#402ACFD9"/>
        </shape>
    </item>
</layer-list>