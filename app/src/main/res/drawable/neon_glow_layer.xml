<?xml version="1.0" encoding="utf-8"?><!-- Outer glow ring effect — set as FrameLayout background --><layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Outermost wide soft glow -->    <item
    android:left="4dp"
    android:right="4dp"
    android:top="4dp"
    android:bottom="4dp">
    <shape android:shape="rectangle">
        <corners android:radius="50dp" />
        <stroke android:width="6dp"
            android:color="#402ACFD9" />
        <solid android:color="@android:color/transparent" />
    </shape>
</item>
    <!-- Mid glow ring -->    <item
    android:left="6dp"
    android:right="6dp"
    android:top="6dp"
    android:bottom="6dp">
    <shape android:shape="rectangle">
        <corners android:radius="50dp" />
        <stroke android:width="4dp"
            android:color="#602ACFD9" />
        <solid android:color="@android:color/transparent" />
    </shape>
</item>
    <!-- Inner bright sharp ring -->    <item
    android:left="8dp"
    android:right="8dp"
    android:top="8dp"
    android:bottom="8dp">
    <shape android:shape="rectangle">
        <corners android:radius="50dp" />
        <stroke android:width="1.5dp"
            android:color="#CC2ACFD9" />
        <solid android:color="#1A1A1A" />
    </shape>
</item>
</layer-list>