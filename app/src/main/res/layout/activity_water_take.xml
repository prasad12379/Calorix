<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0A1628">

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="💧 Pick Your Container"
        android:textColor="#7EC8E3"
        android:textSize="13sp"
        android:letterSpacing="0.15"
        android:textStyle="bold"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="52dp"/>

    <!-- Subtitle -->
    <TextView
        android:id="@+id/subtitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select to log water intake"
        android:textColor="#2A4560"
        android:textSize="11sp"
        android:layout_centerHorizontal="true"
        android:layout_below="@id/titleText"
        android:layout_marginTop="4dp"/>

    <!-- Carousel Row -->
    <RelativeLayout
        android:id="@+id/carouselRow"
        android:layout_width="match_parent"
        android:layout_height="280dp"
        android:layout_below="@id/subtitleText"
        android:layout_marginTop="12dp"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- Previous container peek -->
        <ImageView
            android:id="@+id/prevImage"
            android:layout_width="90dp"
            android:layout_height="110dp"
            android:layout_centerVertical="true"
            android:layout_alignParentStart="true"
            android:layout_marginStart="-18dp"
            android:scaleType="fitCenter"
            android:alpha="0.35"/>

        <!-- Next container peek -->
        <ImageView
            android:id="@+id/nextImage"
            android:layout_width="90dp"
            android:layout_height="110dp"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"
            android:layout_marginEnd="-18dp"
            android:scaleType="fitCenter"
            android:alpha="0.35"/>

        <!-- Main Card -->
        <!-- Main Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/card"
            android:layout_width="210dp"
            android:layout_height="260dp"
            android:layout_centerInParent="true"
            app:cardCornerRadius="36dp"
            app:cardBackgroundColor="#00000000"
            android:background="@null"
            app:cardElevation="0dp">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <View
                    android:id="@+id/glowView"
                    android:layout_width="1dp"
                    android:layout_height="1dp"
                    android:layout_centerInParent="true"
                    android:background="@android:color/transparent"
                    android:visibility="invisible"/>

                <ImageView
                    android:id="@+id/containerImage"
                    android:layout_width="150dp"
                    android:layout_height="180dp"
                    android:layout_centerInParent="true"
                    android:scaleType="fitCenter"
                    android:background="@null"/>

            </RelativeLayout>
        </androidx.cardview.widget.CardView>
    </RelativeLayout>

    <!-- Container Name -->
    <TextView
        android:id="@+id/containerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="#E8F4FD"
        android:textSize="26sp"
        android:textStyle="bold"
        android:letterSpacing="-0.02"
        android:layout_below="@id/carouselRow"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="4dp"/>

    <!-- Volume Badge -->
    <TextView
        android:id="@+id/containerVolume"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="14sp"
        android:textStyle="bold"
        android:background="@drawable/badge_bg"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_below="@id/containerName"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="8dp"/>

    <!-- Dot Indicators -->
    <LinearLayout
        android:id="@+id/dotsLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_below="@id/containerVolume"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="14dp"
        android:gravity="center"/>

    <!-- Add Button -->
    <Button
        android:id="@+id/addButton"
        android:layout_width="220dp"
        android:layout_height="52dp"
        android:text="+ Add Water"
        android:textColor="#FFFFFF"
        android:textSize="15sp"
        android:textStyle="bold"
        android:letterSpacing="0.05"
        android:background="@drawable/button_bg"
        android:layout_below="@id/dotsLayout"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="14dp"
        android:stateListAnimator="@null"/>

    <!-- ── Circular Water Glass ── -->
    <RelativeLayout
        android:id="@+id/glassSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/addButton"
        android:layout_marginTop="18dp"
        android:gravity="center">

        <!-- Custom Water Glass View -->
        <com.example.run.WaterGlassView
            android:id="@+id/waterGlassView"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_centerHorizontal="true"/>

        <!-- ml label inside/below glass -->
        <TextView
            android:id="@+id/mlLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 ml"
            android:textColor="#7EC8E3"
            android:textSize="11sp"
            android:textStyle="bold"
            android:layout_below="@id/waterGlassView"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="6dp"/>

        <!-- Goal label -->
        <TextView
            android:id="@+id/goalLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="/ 2000 ml"
            android:textColor="#1E3550"
            android:textSize="11sp"
            android:layout_below="@id/mlLabel"
            android:layout_centerHorizontal="true"
            android:layout_marginTop="2dp"/>

    </RelativeLayout>

    <!-- Swipe hint -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="← SWIPE TO CHANGE →"
        android:textColor="#1E3550"
        android:textSize="9sp"
        android:letterSpacing="0.1"
        android:layout_below="@id/glassSection"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"/>

</RelativeLayout>