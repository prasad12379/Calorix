<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="30dp">

            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_arrow_back"
                android:padding="8dp"
                app:tint="#FFFFFF"
                android:background="?attr/selectableItemBackgroundBorderless"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Water Tracker"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"/>

            <ImageView
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_water_drop"
                app:tint="#64B5F6"/>
        </LinearLayout>

        <!-- DAILY GOAL SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="25dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card_background"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_target"
                        app:tint="#64B5F6"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Daily Water Goal"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <!-- Animated Water Slider -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center">

                    <!-- Water Amount Display -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center"
                        android:layout_marginBottom="20dp">

                        <TextView
                            android:id="@+id/tvWaterGoal"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2.5"
                            android:textSize="56sp"
                            android:textStyle="bold"
                            android:textColor="#64B5F6"
                            android:fontFamily="sans-serif-condensed"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" L"
                            android:textSize="32sp"
                            android:textColor="#B3FFFFFF"
                            android:layout_marginTop="8dp"/>
                    </LinearLayout>

                    <!-- Slider Track with Water Drops -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="60dp"
                        android:layout_marginBottom="10dp">

                        <!-- Water Drop Icons -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:orientation="horizontal"
                            android:gravity="center">

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_water_drop"
                                app:tint="#4064B5F6"
                                android:layout_marginEnd="15dp"/>

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_water_drop"
                                app:tint="#6064B5F6"
                                android:layout_marginEnd="15dp"/>

                            <ImageView
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:src="@drawable/ic_water_drop"
                                app:tint="#8064B5F6"/>

                            <ImageView
                                android:layout_width="24dp"
                                android:layout_height="24dp"
                                android:src="@drawable/ic_water_drop"
                                app:tint="#6064B5F6"
                                android:layout_marginStart="15dp"/>

                            <ImageView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:src="@drawable/ic_water_drop"
                                app:tint="#4064B5F6"
                                android:layout_marginStart="15dp"/>
                        </LinearLayout>

                        <!-- Slider -->
                        <SeekBar
                            android:id="@+id/seekBarWaterGoal"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:max="80"
                            android:min="5"
                            android:progress="25"
                            android:progressTint="#64B5F6"
                            android:thumbTint="#64B5F6"
                            android:progressBackgroundTint="#30FFFFFF"/>
                    </FrameLayout>

                    <!-- Min/Max Labels -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="0.5 L"
                            android:textSize="12sp"
                            android:textColor="#80FFFFFF"
                            android:gravity="start"/>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="8.0 L"
                            android:textSize="12sp"
                            android:textColor="#80FFFFFF"
                            android:gravity="end"/>
                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- REMINDER TIME SECTION -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="25dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@android:color/transparent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/glass_card_background"
                android:orientation="vertical"
                android:padding="24dp">

                <!-- Title -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="20dp">

                    <ImageView
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_time"
                        app:tint="#FFC107"
                        android:layout_marginEnd="10dp"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reminder Interval"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>
                </LinearLayout>

                <!-- Animated Clock Display -->
                <FrameLayout
                    android:layout_width="200dp"
                    android:layout_height="200dp"
                    android:layout_gravity="center"
                    android:layout_marginBottom="20dp">

                    <!-- Clock Background Circle -->
                    <androidx.cardview.widget.CardView
                        android:layout_width="200dp"
                        android:layout_height="200dp"
                        android:layout_gravity="center"
                        app:cardCornerRadius="100dp"
                        app:cardElevation="8dp"
                        android:backgroundTint="#15FFFFFF">

                        <!-- Clock Face -->
                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <!-- Center Dot -->
                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:layout_gravity="center"
                                android:background="@drawable/circle_shape"
                                android:backgroundTint="#FFC107"/>

                            <!-- Hour Markers -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="vertical"
                                android:gravity="center">

                                <!-- 12 o'clock -->
                                <View
                                    android:layout_width="3dp"
                                    android:layout_height="10dp"
                                    android:background="#80FFFFFF"
                                    android:layout_marginBottom="75dp"/>

                                <Space
                                    android:layout_width="1dp"
                                    android:layout_height="0dp"
                                    android:layout_weight="1"/>

                                <!-- 6 o'clock -->
                                <View
                                    android:layout_width="3dp"
                                    android:layout_height="10dp"
                                    android:background="#80FFFFFF"
                                    android:layout_marginTop="75dp"/>
                            </LinearLayout>

                            <!-- 3 and 9 o'clock markers (horizontal) -->
                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:orientation="horizontal"
                                android:gravity="center">

                                <!-- 9 o'clock -->
                                <View
                                    android:layout_width="10dp"
                                    android:layout_height="3dp"
                                    android:background="#80FFFFFF"
                                    android:layout_marginEnd="75dp"/>

                                <Space
                                    android:layout_width="0dp"
                                    android:layout_height="1dp"
                                    android:layout_weight="1"/>

                                <!-- 3 o'clock -->
                                <View
                                    android:layout_width="10dp"
                                    android:layout_height="3dp"
                                    android:background="#80FFFFFF"
                                    android:layout_marginStart="75dp"/>
                            </LinearLayout>

                            <!-- Hour Hand (Animated) -->
                            <ImageView
                                android:id="@+id/ivClockHand"
                                android:layout_width="80dp"
                                android:layout_height="4dp"
                                android:layout_gravity="center"
                                android:src="@drawable/clock_hand"
                                android:rotation="0"
                                app:tint="#FFC107"/>

                            <!-- Time Display -->
                            <TextView
                                android:id="@+id/tvReminderTime"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_marginTop="60dp"
                                android:text="2 hrs"
                                android:textSize="20sp"
                                android:textStyle="bold"
                                android:textColor="#FFC107"/>

                        </FrameLayout>
                    </androidx.cardview.widget.CardView>

                </FrameLayout>

                <!-- Clock Instruction -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Tap and drag to set reminder interval"
                    android:textSize="12sp"
                    android:textColor="#80FFFFFF"
                    android:gravity="center"
                    android:layout_marginBottom="15dp"/>

                <!-- Quick Preset Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btn1Hour"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        android:backgroundTint="#30FFFFFF"
                        android:foreground="?android:attr/selectableItemBackground">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="1 hr"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btn2Hours"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        android:backgroundTint="#30FFFFFF"
                        android:foreground="?android:attr/selectableItemBackground">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="2 hrs"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                    <androidx.cardview.widget.CardView
                        android:id="@+id/btn3Hours"
                        android:layout_width="0dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp"
                        android:backgroundTint="#30FFFFFF"
                        android:foreground="?android:attr/selectableItemBackground">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:text="3 hrs"
                            android:textSize="13sp"
                            android:textColor="#FFFFFF"
                            android:gravity="center"/>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- TODAY'S INTAKE SECTION -->
        <!-- Drink Water Button -->
        <androidx.cardview.widget.CardView
            android:id="@+id/btnDrinkWater"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            app:cardCornerRadius="30dp"
            app:cardElevation="8dp"
            android:backgroundTint="#4CAF50"
            android:foreground="?android:attr/selectableItemBackground">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="horizontal"
                android:gravity="center">

                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:src="@drawable/ic_water_drop"
                    app:tint="#FFFFFF"
                    android:layout_marginEnd="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ADD WATER INTAKE"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:id="@+id/tvQuickAmount"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" (250ml)"
                    android:textSize="14sp"
                    android:textColor="#E0FFFFFF"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>




    </LinearLayout>
</ScrollView>